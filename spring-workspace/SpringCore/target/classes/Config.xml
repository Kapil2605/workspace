<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
       http://www.springframework.org/schema/beans
       classpath:org/springframework/beans/factory/xml/spring-beans.xsd">

    <bean id="student" class="com.springcore.bean.Student">
        <property name="studentId" value="101"/>
        <property name="studentName" value="Kapil Yadav"/>
        <property name="studentAddress" value="Rewari, Haryana"/>
    </bean>

</beans>
