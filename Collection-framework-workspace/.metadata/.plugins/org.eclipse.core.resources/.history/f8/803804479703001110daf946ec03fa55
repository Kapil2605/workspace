package com.practice.questions;

import java.util.Arrays;
import java.util.List;
import java.util.stream.Collectors;

public class SortInAscendingOrder {
	public static void main(String[] args) {
		List<Integer>list=Arrays.asList(12,14,2,3,13);
		List<Integer>resultAscending=list.stream().sorted((a,b)->a-b).collect(Collectors.toList());
		System.out.println(resultAscending);
		
		List<Integer>resultDescending=list.stream().sorted((a,b)->a-b).collect(Collectors.toList());
		System.out.println(resultDescending);
	}
}
